{
  "name": "mosaic-ts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript front-end for MOSAIC. Drives the Python sidecar (mosaic.bridge) over JSON-RPC.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "mosaic": "./dist/cli/index.js"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.15",
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "1.4.7",
    "commander": "14.0.3",
    "picocolors": "1.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "25.9.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
