# LLM Providers (set the one you use)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# Optional OpenAI-compatible local endpoint (e.g. AMD Lemonade Qwen)
# Default base URL: http://localhost:8020/api/v0 — override here if your
# lemonade-server-dev binary listens on a different port (verify via the
# server's startup log).
LEMONADE_BASE_URL=
LEMONADE_API_KEY=

# Data Providers
TUSHARE_TOKEN=
FRED_API_KEY=
BRAVE_SEARCH_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Optional runtime directories (default: ~/.mosaic and <repo>/data)
MOSAIC_DATA_DIR=
MOSAIC_RESULTS_DIR=
MOSAIC_CACHE_DIR=

# SQLite exact-call cache for routed agent data tools.
# Enabled by default; DB defaults to ${MOSAIC_CACHE_DIR}/agent_data/cache.sqlite3.
# Entries are retained until TTL refresh, max-entry eviction, cleanup, or clear.
# Read TTL defaults to 24h, matching vendor freshness semantics such as FRED revisions.
# Max entries defaults to 50000; set empty/off to disable count-based pruning.
# Empty successful results are not cached by default so transient vendor gaps can refresh.
MOSAIC_AGENT_DATA_CACHE_ENABLED=1
MOSAIC_AGENT_DATA_CACHE_DB=
MOSAIC_AGENT_DATA_CACHE_READ_TTL_SECONDS=86400
MOSAIC_AGENT_DATA_CACHE_MAX_ENTRIES=50000
MOSAIC_AGENT_DATA_CACHE_SKIP_EMPTY_RESULTS=1

# Sidecar Python interpreter discovery (used by mosaic-ts in Phase 1+)
MOSAIC_PYTHON=

# Optional benchmark ticker override
MOSAIC_BENCHMARK_TICKER=

# MiroFish real engine (mirofish --engine oasis): self-hosted MOSAIC-Fish backend.
# Start MOSAIC-Fish (Flask :5001 + Neo4j) then point this at it.
MOSAIC_MIROFISH_URL=http://localhost:5001

# Private prompt repo (autoresearch prompt store + ΔSharpe baseline).
# A LOCAL git clone of haphap/MOSAIC-Prompts, OUTSIDE this repo. Seeded with
# baseline-v0 (curated cohort_default replicated to 7 regime cohorts).
MOSAIC_PRIVATE_PROMPT_REPO=/path/to/MOSAIC-Prompts
MOSAIC_PRIVATE_PROMPT_REPO_ID=haphap/MOSAIC-Prompts
