# LLM Providers (set the one you use)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# Optional OpenAI-compatible local endpoint (e.g. AMD Lemonade Qwen)
# Default base URL: http://localhost:8020/api/v0 — override here if your
# lemonade-server-dev binary listens on a different port (verify via the
# server's startup log).
LEMONADE_BASE_URL=
LEMONADE_API_KEY=

# Data Providers
TUSHARE_TOKEN=
FRED_API_KEY=
BRAVE_SEARCH_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Optional runtime directories (default: ~/.mosaic and <repo>/data)
MOSAIC_DATA_DIR=
MOSAIC_RESULTS_DIR=
MOSAIC_CACHE_DIR=

# Sidecar Python interpreter discovery (used by mosaic-ts in Phase 1+)
MOSAIC_PYTHON=

# Optional benchmark ticker override
MOSAIC_BENCHMARK_TICKER=
