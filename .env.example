# LLM Providers (set the one you use)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# Optional OpenAI-compatible local endpoint (e.g. AMD Lemonade Qwen)
# Default base URL: http://localhost:8020/api/v0 — override here if your
# lemonade-server-dev binary listens on a different port (verify via the
# server's startup log).
LEMONADE_BASE_URL=
LEMONADE_API_KEY=

# Optional MiroFish/OASIS service model overrides.
MOSAIC_MIROFISH_LLM_BASE_URL=
MOSAIC_MIROFISH_LLM_API_KEY=
MOSAIC_MIROFISH_LLM_MODEL=
MOSAIC_MIROFISH_EMBEDDING_BASE_URL=
MOSAIC_MIROFISH_EMBEDDING_API_KEY=
MOSAIC_MIROFISH_EMBEDDING_MODEL=

# Data Providers
TUSHARE_TOKEN=
FRED_API_KEY=
BRAVE_SEARCH_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Optional runtime directories (default: ~/.mosaic and <repo>/data)
MOSAIC_DATA_DIR=
MOSAIC_RESULTS_DIR=
MOSAIC_CACHE_DIR=

# Optional parsed China policy database clone.
# Prefer a local clone of https://github.com/haphap/china-policy-db for stable
# offline PBOC/gov.cn policy reads. The raw base URL is an optional fallback.
MOSAIC_CHINA_POLICY_DB_DIR=
MOSAIC_CHINA_POLICY_DB_RAW_BASE_URL=

# SQLite exact-call cache for routed agent data tools.
# Enabled by default; DB defaults to ${MOSAIC_CACHE_DIR}/agent_data/cache.sqlite3.
# Entries are retained until TTL refresh, max-entry eviction, cleanup, or clear.
# Read TTL defaults to 24h, matching vendor freshness semantics such as FRED revisions.
# Max entries defaults to 50000; set empty/off to disable count-based pruning.
# Empty successful results are not cached by default so transient vendor gaps can refresh.
MOSAIC_AGENT_DATA_CACHE_ENABLED=1
MOSAIC_AGENT_DATA_CACHE_DB=
MOSAIC_AGENT_DATA_CACHE_READ_TTL_SECONDS=86400
MOSAIC_AGENT_DATA_CACHE_MAX_ENTRIES=50000
MOSAIC_AGENT_DATA_CACHE_SKIP_EMPTY_RESULTS=1

# Sidecar Python interpreter discovery (used by mosaic-ts in Phase 1+)
MOSAIC_PYTHON=

# Optional benchmark ticker override
MOSAIC_BENCHMARK_TICKER=

# MiroFish real engine (mirofish --engine oasis): self-hosted MOSAIC-Fish backend.
# Start MOSAIC-Fish (Flask :5001 + Neo4j) then point this at it.
MOSAIC_MIROFISH_URL=http://localhost:5001

# Optional qlib path overrides. Leave empty to use the defaults under ~/.qlib/qlib_data.
QLIB_CN_DATA_PATH=
QLIB_CN_ETF_PATH=

# Prompt source.
# Default agent runs use this repo's bundled prompts under prompts/mosaic.
# Set MOSAIC_PROMPTS_REPO to make all agent prompt loading prefer a LOCAL git
# clone of haphap/MOSAIC-Prompts outside this repo; bundled prompts remain the
# fallback for missing files. MOSAIC_PROMPTS_ROOT may point directly at a
# prompts/mosaic directory instead of a repo root.
MOSAIC_PROMPTS_REPO=
MOSAIC_PROMPTS_ROOT=
MOSAIC_PROMPTS_REPO_ID=haphap/MOSAIC-Prompts

# Backwards-compatible aliases for older tooling.
MOSAIC_PRIVATE_PROMPT_REPO=
MOSAIC_PRIVATE_PROMPT_REPO_ID=haphap/MOSAIC-Prompts
