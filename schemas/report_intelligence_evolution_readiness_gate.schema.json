{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Evolution Readiness Gate",
  "type": "object",
  "required": [
    "gate_id",
    "run_id",
    "as_of_datetime",
    "gate_status",
    "promotion_state",
    "production_prompt_change_allowed",
    "thresholds",
    "checks",
    "requirement_shortfalls",
    "blockers",
    "blocker_count",
    "private_text_included",
    "policy"
  ],
  "properties": {
    "gate_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "data_vintage_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "as_of_datetime": {"type": "string", "minLength": 1},
    "gate_status": {"enum": ["passed", "blocked"]},
    "promotion_state": {"type": "string", "minLength": 1},
    "production_prompt_change_allowed": {"type": "boolean", "const": false},
    "thresholds": {
      "type": "object",
      "required": [
        "min_unique_outcome_claims",
        "min_stock_proxy_claims",
        "min_industry_proxy_claims",
        "min_paper_trading_recipes",
        "min_consecutive_monitor_refreshes",
        "min_consecutive_audit_refreshes",
        "min_gap_distribution_refreshes"
      ],
      "properties": {
        "min_unique_outcome_claims": {"type": "integer", "minimum": 1},
        "min_stock_proxy_claims": {"type": "integer", "minimum": 1},
        "min_industry_proxy_claims": {"type": "integer", "minimum": 1},
        "min_paper_trading_recipes": {"type": "integer", "minimum": 1},
        "min_consecutive_monitor_refreshes": {"type": "integer", "minimum": 1},
        "min_consecutive_audit_refreshes": {"type": "integer", "minimum": 1},
        "min_gap_distribution_refreshes": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "requirement",
          "passed",
          "evidence",
          "blockers"
        ],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "requirement": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "evidence": {"type": "object"},
          "blockers": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "requirement_shortfalls": {
      "type": "object",
      "required": [
        "unique_outcome_claim_count",
        "stock_proxy_unique_claim_count",
        "industry_proxy_unique_claim_count",
        "paper_trading_run_count",
        "paper_trading_validated_recipe_count",
        "after_cost_paper_trading_summary",
        "monitor_distinct_vintage_count",
        "monitor_current_global_blocker_count",
        "audit_distinct_vintage_count",
        "gold_reviewed_claims",
        "gold_pending_claims",
        "gold_quality_metric_gaps",
        "gap_distribution_distinct_vintage_count",
        "markdown_coverage"
      ],
      "properties": {
        "markdown_coverage": {"type": "object"},
        "gold_quality_metric_gaps": {
          "type": "object",
          "required": ["missing_or_below_threshold", "blocker", "next_action"],
          "properties": {
            "missing_or_below_threshold": {
              "type": "array",
              "items": {"type": "string"}
            },
            "blocker": {"type": "string", "minLength": 1},
            "next_action": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        },
        "after_cost_paper_trading_summary": {
          "type": "object",
          "required": ["status", "blocker", "next_action"],
          "properties": {
            "status": {"enum": ["present", "missing", "computed", "insufficient_validated_runs"]},
            "blocker": {"type": "string"},
            "next_action": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": {
        "type": "object",
        "required": ["current", "target", "remaining", "blocker", "next_action"],
        "properties": {
          "current": {"type": "integer", "minimum": 0},
          "target": {"type": "integer", "minimum": 0},
          "remaining": {"type": "integer", "minimum": 0},
          "blocker": {"type": "string", "minLength": 1},
          "next_action": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "blockers": {"type": "array", "items": {"type": "string"}},
    "blocker_count": {"type": "integer", "minimum": 0},
    "private_text_included": {"type": "boolean", "const": false},
    "policy": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
