{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Recipe Paper Trading Run",
  "type": "object",
  "required": [
    "paper_trading_run_id",
    "analysis_recipe_id",
    "experiment_id",
    "pre_registration_hash",
    "protocol_version",
    "promotion_state",
    "validation_status",
    "paper_trading_status",
    "source_method_pattern_ids",
    "required_tools",
    "required_data",
    "decision_scope",
    "entry_condition",
    "exit_condition",
    "risk_controls",
    "expected_horizon_days",
    "benchmark_symbol",
    "benchmark_source",
    "cost_model_id",
    "pre_registered_protocol",
    "metrics",
    "blocked_reasons",
    "profile_weight_support",
    "production_decision_impact_allowed",
    "policy"
  ],
  "properties": {
    "paper_trading_run_id": {"type": "string", "minLength": 1},
    "analysis_recipe_id": {"type": "string", "minLength": 1},
    "experiment_id": {"type": "string", "minLength": 1},
    "pre_registration_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "protocol_version": {"type": "string", "minLength": 1},
    "promotion_state": {"type": "string", "minLength": 1},
    "validation_status": {"enum": ["passed", "blocked"]},
    "paper_trading_status": {"enum": ["passed", "blocked"]},
    "source_method_pattern_ids": {"type": "array", "items": {"type": "string"}},
    "required_tools": {"type": "array", "items": {"type": "string"}},
    "required_data": {
      "type": "array",
      "items": {"type": "string", "pattern": "^metric:[0-9a-zA-Z_\\u4e00-\\u9fff]+$"},
      "uniqueItems": true
    },
    "decision_scope": {"type": "string"},
    "entry_condition": {"type": "string", "minLength": 1},
    "exit_condition": {"type": "string", "minLength": 1},
    "risk_controls": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "expected_horizon_days": {"type": "integer", "minimum": 1},
    "benchmark_symbol": {"type": "string", "minLength": 1},
    "benchmark_source": {"type": "string", "minLength": 1},
    "cost_model_id": {"type": "string", "minLength": 1},
    "pre_registered_protocol": {
      "type": "object",
      "required": [
        "entry_semantics",
        "exit_semantics",
        "cost_model_id",
        "benchmark_symbol",
        "benchmark_source",
        "slippage_model_id",
        "round_trip_cost_includes_slippage",
        "backtest_window_policy",
        "out_of_sample_window_policy",
        "out_of_sample_fraction",
        "minimum_out_of_sample_effective_n",
        "parameter_lock_policy",
        "minimum_effective_n",
        "max_drawdown",
        "alpha_decay_fail_streak",
        "max_horizon_contribution_share",
        "max_regime_contribution_share",
        "minimum_horizon_count",
        "minimum_regime_count",
        "cost_decay_turnover_threshold",
        "profile_weight_is_sufficient",
        "parameter_tuning_after_results_allowed",
        "production_decision_impact_allowed"
      ],
      "properties": {
        "entry_semantics": {"type": "string", "minLength": 1},
        "exit_semantics": {"type": "string", "minLength": 1},
        "cost_model_id": {"type": "string", "minLength": 1},
        "benchmark_symbol": {"type": "string", "minLength": 1},
        "benchmark_source": {"type": "string", "minLength": 1},
        "slippage_model_id": {"type": "string", "minLength": 1},
        "round_trip_cost_includes_slippage": {"type": "boolean", "const": true},
        "backtest_window_policy": {"type": "string", "minLength": 1},
        "out_of_sample_window_policy": {"type": "string", "minLength": 1},
        "out_of_sample_fraction": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "minimum_out_of_sample_effective_n": {"type": "number", "minimum": 0},
        "parameter_lock_policy": {"type": "string", "minLength": 1},
        "minimum_effective_n": {"type": "number", "minimum": 0},
        "max_drawdown": {"type": "number", "minimum": 0},
        "alpha_decay_fail_streak": {"type": "integer", "minimum": 1},
        "max_horizon_contribution_share": {"type": "number", "minimum": 0, "maximum": 1},
        "max_regime_contribution_share": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_horizon_count": {"type": "integer", "minimum": 1},
        "minimum_regime_count": {"type": "integer", "minimum": 1},
        "cost_decay_turnover_threshold": {"type": "number", "minimum": 0},
        "profile_weight_is_sufficient": {"type": "boolean", "const": false},
        "parameter_tuning_after_results_allowed": {"type": "boolean", "const": false},
        "production_decision_impact_allowed": {"type": "boolean", "const": false}
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "required": [
        "annualized_return",
        "benchmark_return",
        "alpha",
        "sharpe",
        "max_drawdown",
        "turnover",
        "hit_rate",
        "effective_n",
        "cost_adjusted_alpha",
        "alpha_decay_slope",
        "calibration_error",
        "drawdown_breach_count"
      ],
      "properties": {
        "annualized_return": {"type": ["number", "null"]},
        "benchmark_return": {"type": ["number", "null"]},
        "alpha": {"type": ["number", "null"]},
        "sharpe": {"type": ["number", "null"]},
        "max_drawdown": {"type": ["number", "null"]},
        "turnover": {"type": ["number", "null"], "minimum": 0},
        "hit_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "effective_n": {"type": "number", "minimum": 0},
        "cost_adjusted_alpha": {"type": ["number", "null"]},
        "alpha_decay_slope": {"type": ["number", "null"]},
        "calibration_error": {"type": ["number", "null"], "minimum": 0},
        "drawdown_breach_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "blocked_reasons": {"type": "array", "items": {"type": "string"}},
    "profile_weight_support": {"type": "object"},
    "production_decision_impact_allowed": {"type": "boolean", "const": false},
    "policy": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
