{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Recipe Paper Trading Run",
  "type": "object",
  "required": [
    "paper_trading_run_id",
    "analysis_recipe_id",
    "experiment_id",
    "pre_registration_hash",
    "protocol_version",
    "promotion_state",
    "validation_status",
    "paper_trading_status",
    "source_method_pattern_ids",
    "required_tools",
    "entry_condition",
    "exit_condition",
    "risk_controls",
    "benchmark_symbol",
    "benchmark_source",
    "cost_model_id",
    "metrics",
    "blocked_reasons",
    "profile_weight_support",
    "production_decision_impact_allowed",
    "policy"
  ],
  "properties": {
    "paper_trading_run_id": {"type": "string", "minLength": 1},
    "analysis_recipe_id": {"type": "string", "minLength": 1},
    "experiment_id": {"type": "string", "minLength": 1},
    "pre_registration_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "protocol_version": {"type": "string", "minLength": 1},
    "promotion_state": {"type": "string", "minLength": 1},
    "validation_status": {"enum": ["passed", "blocked"]},
    "paper_trading_status": {"enum": ["passed", "blocked"]},
    "source_method_pattern_ids": {"type": "array", "items": {"type": "string"}},
    "required_tools": {"type": "array", "items": {"type": "string"}},
    "required_data": {"type": "array"},
    "decision_scope": {"type": "string"},
    "entry_condition": {"type": "string", "minLength": 1},
    "exit_condition": {"type": "string", "minLength": 1},
    "risk_controls": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "expected_horizon_days": {"type": "integer", "minimum": 1},
    "benchmark_symbol": {"type": "string", "minLength": 1},
    "benchmark_source": {"type": "string", "minLength": 1},
    "cost_model_id": {"type": "string", "minLength": 1},
    "metrics": {"type": "object"},
    "blocked_reasons": {"type": "array", "items": {"type": "string"}},
    "profile_weight_support": {"type": "object"},
    "production_decision_impact_allowed": {"type": "boolean", "const": false},
    "policy": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
