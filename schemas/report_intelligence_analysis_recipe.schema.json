{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Analysis Recipe",
  "type": "object",
  "required": ["analysis_recipe_id", "recipe_id", "name", "method_pattern_id", "source_method_pattern_ids", "version", "promotion_state", "runtime_mode", "required_tools", "required_data", "decision_scope", "entry_condition", "exit_condition", "risk_controls", "expected_horizon_days", "steps", "output_signal", "validation_status", "promotion_requirements"],
  "properties": {
    "analysis_recipe_id": {"type": "string", "minLength": 1},
    "recipe_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "method_pattern_id": {"type": "string", "minLength": 1},
    "source_method_pattern_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "version": {"type": "string", "minLength": 1},
    "promotion_state": {"type": "string", "minLength": 1},
    "runtime_mode": {"type": "string", "minLength": 1},
    "required_tools": {"type": "array", "items": {"type": "string"}},
    "required_data": {"type": "array", "items": {"type": "string"}},
    "decision_scope": {"type": "string", "minLength": 1},
    "entry_condition": {"type": "string", "minLength": 1},
    "exit_condition": {"type": "string", "minLength": 1},
    "risk_controls": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "expected_horizon_days": {"type": "integer", "minimum": 1},
    "steps": {"type": "array"},
    "output_signal": {"type": "object"},
    "validation_status": {"type": "string", "minLength": 1},
    "promotion_requirements": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
