{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Macro Market Series Catalog",
  "type": "object",
  "required": [
    "catalog_id",
    "schema_version",
    "series_id",
    "series_family",
    "source",
    "source_endpoint",
    "instrument",
    "quote_convention",
    "unit",
    "calendar",
    "frequency",
    "latest_observation_date",
    "earliest_observation_date",
    "point_in_time_policy",
    "license_boundary",
    "target_agent_candidates",
    "implementation_status",
    "readiness_status",
    "gap_reason",
    "raw_observations_included",
    "private_text_included"
  ],
  "properties": {
    "catalog_id": {"type": "string", "minLength": 1},
    "schema_version": {"const": "macro_market_series_catalog_v1"},
    "series_id": {"type": "string", "minLength": 1},
    "series_family": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "source_endpoint": {"type": "string", "minLength": 1},
    "instrument": {"type": "string", "minLength": 1},
    "quote_convention": {"type": "string"},
    "unit": {"type": "string"},
    "calendar": {"type": "string", "minLength": 1},
    "frequency": {"type": "string", "minLength": 1},
    "latest_observation_date": {"type": "string"},
    "earliest_observation_date": {"type": "string"},
    "point_in_time_policy": {"type": "string", "minLength": 1},
    "license_boundary": {"type": "string", "minLength": 1},
    "target_agent_candidates": {
      "type": "array",
      "items": {"type": "string"}
    },
    "implementation_status": {"type": "string", "minLength": 1},
    "readiness_status": {"type": "string", "minLength": 1},
    "gap_reason": {"type": "string"},
    "long_leg_series_id": {"type": "string"},
    "short_leg_series_id": {"type": "string"},
    "raw_observations_included": {"const": false},
    "private_text_included": {"const": false}
  },
  "additionalProperties": false
}
