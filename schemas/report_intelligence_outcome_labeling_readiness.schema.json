{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Outcome Labeling Readiness",
  "type": "object",
  "required": [
    "readiness_id",
    "forecast_claim_count",
    "forecast_ledger_count",
    "ready_for_outcome_labeling_count",
    "blocked_count",
    "test_status_counts",
    "mapping_gap_counts",
    "ready_forecast_claim_ids",
    "blocked_reason",
    "minimum_required_mapping",
    "policy",
    "next_actions"
  ],
  "properties": {
    "readiness_id": {"type": "string", "minLength": 1},
    "forecast_claim_count": {"type": "integer"},
    "forecast_ledger_count": {"type": "integer"},
    "ready_for_outcome_labeling_count": {"type": "integer"},
    "blocked_count": {"type": "integer"},
    "test_status_counts": {"type": "object"},
    "mapping_gap_counts": {"type": "object"},
    "ready_forecast_claim_ids": {"type": "array", "items": {"type": "string"}},
    "blocked_reason": {"type": "string"},
    "minimum_required_mapping": {"type": "array", "items": {"type": "string"}},
    "policy": {"type": "string", "minLength": 1},
    "next_actions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
