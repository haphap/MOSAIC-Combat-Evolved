{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Mutation Transaction v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mutation_id",
    "transaction_id",
    "experiment_id",
    "state",
    "recovery_state",
    "base_release_id",
    "catalog_hash",
    "schema_hash",
    "evaluation_contract_hash",
    "target_paths",
    "components",
    "metadata_log",
    "created_at",
    "prepared_at",
    "committed_at",
    "aborted_at",
    "recovery_decision"
  ],
  "properties": {
    "schema_version": {
      "const": "prompt_mutation_transaction_v1"
    },
    "mutation_id": {
      "type": "string",
      "minLength": 1
    },
    "transaction_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "enum": ["created", "prepared", "committed_log_pending", "committed", "aborted"]
    },
    "recovery_state": {
      "enum": ["not_needed", "pending", "reconciled"]
    },
    "base_release_id": {
      "type": "string",
      "minLength": 1
    },
    "catalog_hash": {
      "$ref": "#/$defs/sha256"
    },
    "schema_hash": {
      "$ref": "#/$defs/sha256"
    },
    "evaluation_contract_hash": {
      "$ref": "#/$defs/sha256"
    },
    "target_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^/"
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo_id",
          "base_commit",
          "new_commit",
          "candidate_ref",
          "prepare_status",
          "files"
        ],
        "properties": {
          "repo_id": {
            "type": "string",
            "minLength": 1
          },
          "base_commit": {
            "type": "string",
            "minLength": 7
          },
          "new_commit": {
            "type": ["string", "null"],
            "minLength": 7
          },
          "candidate_ref": {
            "type": "string",
            "minLength": 1
          },
          "prepare_status": {
            "enum": ["pending", "prepared", "aborted"]
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "old_hash", "new_hash", "staging_path_hash"],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "old_hash": {
                  "$ref": "#/$defs/sha256"
                },
                "new_hash": {
                  "$ref": "#/$defs/sha256"
                },
                "staging_path_hash": {
                  "$ref": "#/$defs/sha256"
                }
              }
            }
          }
        }
      }
    },
    "metadata_log": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "entry_hash", "appended"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "entry_hash": {
          "$ref": "#/$defs/sha256"
        },
        "appended": {
          "type": "boolean"
        }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "prepared_at": {
      "type": ["string", "null"]
    },
    "committed_at": {
      "type": ["string", "null"]
    },
    "aborted_at": {
      "type": ["string", "null"]
    },
    "recovery_decision": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
