{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Governance Values v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent",
    "cohort",
    "prompt_ir_scope",
    "prompt_ir_hash",
    "generator_version",
    "values_by_path",
    "weight_groups",
    "last_mutation_id"
  ],
  "properties": {
    "schema_version": {
      "const": "prompt_governance_values_v1"
    },
    "agent": {
      "type": "string",
      "pattern": "^(macro|sector|superinvestor|decision)\\.[a-z][a-z0-9_]*$"
    },
    "cohort": {
      "type": "string",
      "minLength": 1
    },
    "prompt_ir_scope": {
      "const": "*"
    },
    "prompt_ir_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "generator_version": {
      "const": "prompt_governance_projection_v1"
    },
    "values_by_path": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^/rule_packs/"
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "weight_groups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_weights"],
      "properties": {
        "evidence_weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["normalization", "members"],
          "properties": {
            "normalization": {
              "const": "sum_to_one"
            },
            "members": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^/rule_packs/"
              }
            }
          }
        }
      }
    },
    "last_mutation_id": {
      "type": ["string", "null"]
    }
  }
}
