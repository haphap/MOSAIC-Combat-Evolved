{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Macro Regime Calendar Row",
  "type": "object",
  "required": [
    "regime_id",
    "regime_type",
    "start_date",
    "end_date",
    "source",
    "pit_available",
    "policy",
    "version"
  ],
  "properties": {
    "regime_id": {"type": "string", "minLength": 1},
    "regime_type": {"type": "string", "minLength": 1},
    "start_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "end_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "source": {"type": "string", "minLength": 1},
    "pit_available": {"type": "boolean", "const": true},
    "policy": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": true
}
