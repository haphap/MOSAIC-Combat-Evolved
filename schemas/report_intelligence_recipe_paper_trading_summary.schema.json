{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Recipe Paper Trading Summary",
  "type": "object",
  "required": [
    "summary_id",
    "run_id",
    "as_of_datetime",
    "protocol_version",
    "recipe_count",
    "paper_trading_run_count",
    "validation_pass_count",
    "blocked_count",
    "status_counts",
    "blocker_counts",
    "passed_recipe_ids",
    "blocked_recipe_ids",
    "profile_paper_trade_disagreement_count",
    "minimum_effective_n",
    "pre_registration_policy",
    "validation_protocol",
    "policy"
  ],
  "properties": {
    "summary_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "as_of_datetime": {"type": "string", "minLength": 1},
    "protocol_version": {"type": "string", "minLength": 1},
    "recipe_count": {"type": "integer", "minimum": 0},
    "paper_trading_run_count": {"type": "integer", "minimum": 0},
    "validation_pass_count": {"type": "integer", "minimum": 0},
    "blocked_count": {"type": "integer", "minimum": 0},
    "status_counts": {"type": "object"},
    "blocker_counts": {"type": "object"},
    "passed_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "blocked_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "profile_paper_trade_disagreement_count": {"type": "integer", "minimum": 0},
    "mean_cost_adjusted_alpha": {"type": ["number", "null"]},
    "minimum_effective_n": {"type": "number", "minimum": 0},
    "pre_registration_policy": {"type": "string", "minLength": 1},
    "validation_protocol": {"type": "object"},
    "policy": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
