{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Release Canary Event v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "run_id",
    "agent_invocation_id",
    "release_id",
    "account_mode",
    "traffic_percent",
    "agent",
    "stage",
    "stage_snapshot_hash",
    "observed_at",
    "prompt_source",
    "prompt_load_failed",
    "schema_failed",
    "fallback",
    "source_failed",
    "unsupported_influence_rejected",
    "validator_rejected",
    "latency_ms",
    "tokenizer_id",
    "tokenizer_version",
    "context_window_tokens",
    "system_prompt_tokens",
    "system_prompt_cap_tokens",
    "token_budget_breached",
    "validator_ids",
    "duplicate_order_intent_count",
    "exposure_breach_count"
  ],
  "properties": {
    "schema_version": { "const": "prompt_release_canary_event_v2" },
    "event_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_invocation_id": { "type": "string", "minLength": 1 },
    "release_id": { "type": "string", "minLength": 1 },
    "account_mode": { "enum": ["paper", "backtest", "live"] },
    "traffic_percent": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 100 },
    "agent": { "type": "string", "minLength": 1 },
    "stage": {
      "enum": [
        "agent_run",
        "alpha_discovery",
        "cio_proposal",
        "cro_review",
        "execution_feasibility",
        "cio_final"
      ]
    },
    "stage_snapshot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "observed_at": { "type": "string", "format": "date-time" },
    "prompt_source": { "enum": ["private", "bundled_fallback", "unavailable"] },
    "prompt_load_failed": { "type": "boolean" },
    "schema_failed": { "type": "boolean" },
    "fallback": { "type": "boolean" },
    "source_failed": { "type": "boolean" },
    "unsupported_influence_rejected": { "type": "boolean" },
    "validator_rejected": { "type": "boolean" },
    "latency_ms": { "type": "number", "minimum": 0 },
    "tokenizer_id": { "const": "cl100k_base" },
    "tokenizer_version": { "const": "1.0.21" },
    "context_window_tokens": { "type": "integer", "minimum": 1 },
    "system_prompt_tokens": { "type": "integer", "minimum": 0 },
    "system_prompt_cap_tokens": { "type": "integer", "minimum": 1 },
    "token_budget_breached": { "type": "boolean" },
    "validator_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "duplicate_order_intent_count": { "type": "integer", "minimum": 0 },
    "exposure_breach_count": { "type": "integer", "minimum": 0 }
  },
  "allOf": [
    {
      "if": { "properties": { "prompt_load_failed": { "const": true } } },
      "then": {
        "properties": {
          "prompt_source": { "const": "unavailable" },
          "system_prompt_tokens": { "const": 0 },
          "schema_failed": { "const": true },
          "fallback": { "const": true },
          "source_failed": { "const": true }
        }
      }
    },
    {
      "if": { "properties": { "prompt_load_failed": { "const": false } } },
      "then": {
        "properties": {
          "prompt_source": { "enum": ["private", "bundled_fallback"] },
          "system_prompt_tokens": { "minimum": 1 }
        }
      }
    },
    {
      "if": { "properties": { "prompt_source": { "const": "bundled_fallback" } } },
      "then": {
        "properties": {
          "fallback": { "const": true },
          "source_failed": { "const": true }
        }
      }
    }
  ]
}
