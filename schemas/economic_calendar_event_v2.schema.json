{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Point-in-time economic calendar event revision v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "calendar_event_id",
    "event_revision_id",
    "supersedes_revision_id",
    "retrieval_batch_id",
    "country",
    "currency",
    "normalized_event",
    "raw_date",
    "raw_time",
    "reference_period",
    "release_stage",
    "occurrence_key",
    "occurrence_anchor_date",
    "scheduled_at",
    "released_at",
    "timezone",
    "time_status",
    "raw_actual",
    "raw_previous",
    "raw_forecast",
    "actual",
    "previous",
    "forecast",
    "unit",
    "actual_parse_status",
    "previous_parse_status",
    "forecast_parse_status",
    "event_phase",
    "conflict_status",
    "conflict_fields",
    "conflict_resolution_evidence_ids",
    "reconciliation_status",
    "retrieved_at",
    "valid_from",
    "valid_to",
    "raw_row_hashes",
    "source_evidence_id",
    "evidence_bundle_id"
  ],
  "properties": {
    "calendar_event_id": { "type": "string", "minLength": 1 },
    "event_revision_id": { "type": "string", "minLength": 1 },
    "supersedes_revision_id": { "type": ["string", "null"] },
    "retrieval_batch_id": { "type": "string", "minLength": 1 },
    "country": { "type": "string", "minLength": 1 },
    "currency": { "type": "string", "minLength": 1 },
    "normalized_event": { "type": "string", "minLength": 1 },
    "raw_date": { "type": "string", "format": "date" },
    "raw_time": { "type": ["string", "null"] },
    "reference_period": { "type": ["string", "null"] },
    "release_stage": { "enum": ["PRELIMINARY", "REVISION", "FINAL", "UNSPECIFIED"] },
    "occurrence_key": { "type": "string", "minLength": 1 },
    "occurrence_anchor_date": { "type": "string", "format": "date" },
    "scheduled_at": { "type": ["string", "null"], "format": "date-time" },
    "released_at": { "type": ["string", "null"], "format": "date-time" },
    "timezone": { "type": ["string", "null"] },
    "time_status": { "enum": ["VERIFIED", "UNVERIFIED"] },
    "raw_actual": { "type": ["string", "null"] },
    "raw_previous": { "type": ["string", "null"] },
    "raw_forecast": { "type": ["string", "null"] },
    "actual": { "type": ["number", "null"] },
    "previous": { "type": ["number", "null"] },
    "forecast": { "type": ["number", "null"] },
    "unit": { "type": ["string", "null"] },
    "actual_parse_status": { "enum": ["PARSED", "FAILED", "EMPTY"] },
    "previous_parse_status": { "enum": ["PARSED", "FAILED", "EMPTY"] },
    "forecast_parse_status": { "enum": ["PARSED", "FAILED", "EMPTY"] },
    "event_phase": { "enum": ["SCHEDULED", "RELEASED", "REVISED"] },
    "conflict_status": { "enum": ["CLEAR", "CONFLICT", "RESOLVED"] },
    "conflict_fields": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["ACTUAL", "PREVIOUS", "FORECAST"] }
    },
    "conflict_resolution_evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "reconciliation_status": {
      "enum": ["EXACT", "WITHIN_TOLERANCE", "EXPECTED_REVISION", "CONFLICT", "UNVERIFIED"]
    },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": ["string", "null"], "format": "date-time" },
    "raw_row_hashes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
    },
    "source_evidence_id": { "type": "string", "minLength": 1 },
    "evidence_bundle_id": { "type": "string", "minLength": 1 }
  }
}
