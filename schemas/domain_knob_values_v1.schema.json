{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Knob Values v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent",
    "cohort",
    "catalog_version",
    "values_by_path",
    "weight_groups",
    "cross_field_groups",
    "last_mutation_id"
  ],
  "properties": {
    "schema_version": {
      "const": "domain_knob_values_v1"
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "cohort": {
      "type": "string",
      "minLength": 1
    },
    "catalog_version": {
      "const": "domain_knob_catalog_v1"
    },
    "values_by_path": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "string", "boolean", "null"]
      }
    },
    "weight_groups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["members"],
        "properties": {
          "normalization": {
            "enum": ["sum_to_one"]
          },
          "members": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^/rule_packs/"
            }
          }
        }
      }
    },
    "cross_field_groups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["members"],
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^/rule_packs/"
            }
          }
        }
      }
    },
    "last_mutation_id": {
      "type": ["string", "null"]
    }
  }
}
