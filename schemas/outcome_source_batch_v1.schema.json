{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "outcome_source_batch_v1"
    },
    "source_batch_id": { "type": "string", "minLength": 1 },
    "source_batch_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "authority_registry_version": {
      "type": "string",
      "const": "outcome_source_authority_registry_v1"
    },
    "authority_registry_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "authority_registry_schema_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "receipt_schema_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "batch_schema_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "scheduled_sample_id": { "type": "string", "minLength": 1 },
    "outcome_schedule_slot_id": { "type": "string", "minLength": 1 },
    "outcome_schedule_slot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evaluation_opportunity_set_id": { "type": "string", "minLength": 1 },
    "evaluation_opportunity_set_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "accepted_output_id": { "type": "string", "minLength": 1 },
    "accepted_output_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "track_key_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "agent_id": { "type": "string", "minLength": 1 },
    "opportunity_as_of": { "type": "string", "format": "date-time" },
    "outcome_due_at": { "type": "string", "format": "date-time" },
    "matured_at": { "type": "string", "format": "date-time" },
    "projection_status": {
      "type": "string",
      "enum": ["SCORE", "ABSTAIN"]
    },
    "realized_metric_schema_id": { "type": "string", "minLength": 1 },
    "realized_metrics": { "type": "object" },
    "source_evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "receipt_refs_by_required_source_id": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "required_source_id": { "type": "string", "minLength": 1 },
          "source_receipt_id": { "type": "string", "minLength": 1 },
          "source_receipt_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "authority_entry_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "vintage_at": { "type": "string", "format": "date-time" },
          "ingested_at": { "type": "string", "format": "date-time" }
        },
        "required": [
          "required_source_id",
          "source_receipt_id",
          "source_receipt_hash",
          "authority_entry_hash",
          "vintage_at",
          "ingested_at"
        ],
        "additionalProperties": false
      }
    },
    "observed_through_at": { "type": "string", "format": "date-time" },
    "released_at": { "type": "string", "format": "date-time" },
    "vintage_at": { "type": "string", "format": "date-time" },
    "verified_at": { "type": "string", "format": "date-time" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "sealed_at": { "type": "string", "format": "date-time" },
    "abstain_reason": {
      "type": ["string", "null"],
      "enum": [
        null,
        "EXOGENOUS_MARKET_DISRUPTION",
        "OUTCOME_NOT_OBSERVABLE"
      ]
    }
  },
  "required": [
    "schema_version",
    "source_batch_id",
    "source_batch_hash",
    "authority_registry_version",
    "authority_registry_hash",
    "authority_registry_schema_hash",
    "receipt_schema_hash",
    "batch_schema_hash",
    "scheduled_sample_id",
    "outcome_schedule_slot_id",
    "outcome_schedule_slot_hash",
    "evaluation_opportunity_set_id",
    "evaluation_opportunity_set_hash",
    "accepted_output_id",
    "accepted_output_hash",
    "track_key_hash",
    "agent_id",
    "opportunity_as_of",
    "outcome_due_at",
    "matured_at",
    "projection_status",
    "realized_metric_schema_id",
    "realized_metrics",
    "source_evidence_ids",
    "receipt_refs_by_required_source_id",
    "observed_through_at",
    "released_at",
    "vintage_at",
    "verified_at",
    "ingested_at",
    "sealed_at",
    "abstain_reason"
  ],
  "additionalProperties": false
}
