{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Evaluation Preregistration v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "experiment_family_id",
    "registered_at",
    "calendar_id",
    "split_policy",
    "primary_metric",
    "secondary_guardrails",
    "min_effect_size",
    "min_samples_per_split",
    "common_support_required",
    "regime_guardrail",
    "multiple_testing"
  ],
  "properties": {
    "schema_version": {
      "const": "domain_evaluation_preregistration_v1"
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "experiment_family_id": {
      "type": "string",
      "minLength": 1
    },
    "registered_at": {
      "type": "string",
      "minLength": 1
    },
    "calendar_id": {
      "const": "cn_a_share"
    },
    "split_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "evaluation", "holdout", "purge_days", "embargo_days"],
      "properties": {
        "train": {
          "$ref": "#/$defs/window"
        },
        "evaluation": {
          "$ref": "#/$defs/window"
        },
        "holdout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["holdout_id", "start", "end", "reuse_budget"],
          "properties": {
            "holdout_id": {
              "$ref": "#/$defs/sha256"
            },
            "start": {
              "type": "string",
              "minLength": 1
            },
            "end": {
              "type": "string",
              "minLength": 1
            },
            "reuse_budget": {
              "const": 1
            }
          }
        },
        "purge_days": {
          "type": "integer",
          "minimum": 1
        },
        "embargo_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "primary_metric": {
      "type": "string",
      "minLength": 1
    },
    "secondary_guardrails": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metric_id", "direction", "max_degradation"],
        "properties": {
          "metric_id": {
            "type": "string",
            "minLength": 1
          },
          "direction": {
            "enum": ["higher_is_better", "lower_is_better"]
          },
          "max_degradation": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "min_effect_size": {
      "type": "number",
      "minimum": 0
    },
    "min_samples_per_split": {
      "type": "integer",
      "minimum": 1
    },
    "common_support_required": {
      "const": true
    },
    "regime_guardrail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_regimes", "min_samples_per_regime", "max_degradation"],
      "properties": {
        "required_regimes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "min_samples_per_regime": {
          "type": "integer",
          "minimum": 1
        },
        "max_degradation": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "multiple_testing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "family_size",
        "candidate_rank",
        "attempt_index",
        "alpha",
        "adjusted_alpha"
      ],
      "properties": {
        "method": {
          "const": "benjamini_hochberg"
        },
        "family_size": {
          "type": "integer",
          "minimum": 1
        },
        "candidate_rank": {
          "type": "integer",
          "minimum": 1
        },
        "attempt_index": {
          "type": "integer",
          "minimum": 1
        },
        "alpha": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        },
        "adjusted_alpha": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        }
      }
    }
  },
  "$defs": {
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "string",
          "minLength": 1
        },
        "end": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
