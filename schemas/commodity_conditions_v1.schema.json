{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deterministic PIT commodity conditions v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "as_of_date",
    "market_session_date",
    "families",
    "conditions_hash"
  ],
  "properties": {
    "schema_version": { "const": "commodity_conditions_v1" },
    "as_of_date": { "type": "string", "format": "date" },
    "market_session_date": { "type": "string", "format": "date" },
    "families": {
      "type": "object",
      "additionalProperties": false,
      "required": ["SC@INE", "CU@SHFE", "AU@SHFE", "C@DCE", "M@DCE"],
      "properties": {
        "SC@INE": { "$ref": "#/$defs/family" },
        "CU@SHFE": { "$ref": "#/$defs/family" },
        "AU@SHFE": { "$ref": "#/$defs/family" },
        "C@DCE": { "$ref": "#/$defs/family" },
        "M@DCE": { "$ref": "#/$defs/family" }
      }
    },
    "conditions_hash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ts_code",
        "symbol",
        "exchange",
        "name",
        "fut_code",
        "multiplier",
        "trade_unit",
        "quote_unit",
        "list_date",
        "delist_date",
        "delivery_month",
        "last_delivery_date",
        "trade_date",
        "settle",
        "volume",
        "open_interest",
        "metadata_released_at",
        "metadata_vintage_at",
        "price_released_at",
        "price_vintage_at",
        "metadata_source",
        "price_source",
        "pit_status",
        "metadata_evidence_id",
        "price_evidence_id"
      ],
      "properties": {
        "ts_code": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "exchange": { "enum": ["INE", "SHFE", "DCE"] },
        "name": { "type": "string", "minLength": 1 },
        "fut_code": { "type": "string", "minLength": 1 },
        "multiplier": { "type": "number", "exclusiveMinimum": 0 },
        "trade_unit": { "type": "string", "minLength": 1, "maxLength": 64 },
        "quote_unit": { "type": "string", "minLength": 1, "maxLength": 64 },
        "list_date": { "type": "string", "format": "date" },
        "delist_date": { "type": "string", "format": "date" },
        "delivery_month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "last_delivery_date": { "type": "string", "format": "date" },
        "trade_date": { "type": "string", "format": "date" },
        "settle": { "type": "number", "exclusiveMinimum": 0 },
        "volume": { "type": "number", "exclusiveMinimum": 0 },
        "open_interest": { "type": "number", "exclusiveMinimum": 0 },
        "metadata_released_at": { "$ref": "#/$defs/timestamp" },
        "metadata_vintage_at": { "$ref": "#/$defs/timestamp" },
        "price_released_at": { "$ref": "#/$defs/timestamp" },
        "price_vintage_at": { "$ref": "#/$defs/timestamp" },
        "metadata_source": { "type": "string", "minLength": 1 },
        "price_source": { "type": "string", "minLength": 1 },
        "pit_status": { "const": "AVAILABLE_AS_OF" },
        "metadata_evidence_id": { "$ref": "#/$defs/evidence_id" },
        "price_evidence_id": { "$ref": "#/$defs/evidence_id" }
      }
    },
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "series_id",
        "family_id",
        "observation_date",
        "released_at",
        "vintage_at",
        "actual",
        "previous",
        "unit",
        "source",
        "pit_status",
        "evidence_id"
      ],
      "properties": {
        "series_id": { "type": "string", "minLength": 1 },
        "family_id": { "type": "string", "minLength": 1 },
        "observation_date": { "type": "string", "format": "date" },
        "released_at": { "$ref": "#/$defs/timestamp" },
        "vintage_at": { "$ref": "#/$defs/timestamp" },
        "actual": { "type": "number", "minimum": 0 },
        "previous": { "type": ["number", "null"], "minimum": 0 },
        "unit": { "type": "string", "minLength": 1, "maxLength": 64 },
        "source": { "type": "string", "minLength": 1 },
        "pit_status": { "const": "AVAILABLE_AS_OF" },
        "evidence_id": { "$ref": "#/$defs/evidence_id" }
      }
    },
    "term_structure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "near_contract",
        "far_contract",
        "near_delist_date",
        "far_delist_date",
        "near_settle",
        "far_settle",
        "days_between_delist_dates",
        "spread_ratio",
        "annualized_carry"
      ],
      "properties": {
        "state": { "enum": ["CONTANGO", "BACKWARDATION", "FLAT"] },
        "near_contract": { "type": "string", "minLength": 1 },
        "far_contract": { "type": "string", "minLength": 1 },
        "near_delist_date": { "type": "string", "format": "date" },
        "far_delist_date": { "type": "string", "format": "date" },
        "near_settle": { "type": "number", "exclusiveMinimum": 0 },
        "far_settle": { "type": "number", "exclusiveMinimum": 0 },
        "days_between_delist_dates": { "type": "integer", "minimum": 1 },
        "spread_ratio": { "type": "number" },
        "annualized_carry": { "type": "number" }
      }
    },
    "source_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_metadata", "daily_settlement", "inventory"],
      "properties": {
        "contract_metadata": { "type": "string", "minLength": 1 },
        "daily_settlement": { "type": "string", "minLength": 1 },
        "inventory": { "type": "string", "minLength": 1 }
      }
    },
    "family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "component",
        "roll_rule_id",
        "trade_date",
        "contracts",
        "selected_contracts",
        "term_structure",
        "inventory",
        "source_identity",
        "evidence_ids",
        "family_hash"
      ],
      "properties": {
        "family_id": { "type": "string", "minLength": 1 },
        "component": {
          "enum": ["energy", "industrial_metals", "gold", "agriculture_food"]
        },
        "roll_rule_id": { "const": "first_two_roll_eligible_by_delist_date_v1" },
        "trade_date": { "type": "string", "format": "date" },
        "contracts": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/contract" }
        },
        "selected_contracts": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "term_structure": { "$ref": "#/$defs/term_structure" },
        "inventory": { "$ref": "#/$defs/inventory" },
        "source_identity": { "$ref": "#/$defs/source_identity" },
        "evidence_ids": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence_id" }
        },
        "family_hash": { "$ref": "#/$defs/hash" }
      }
    }
  }
}
