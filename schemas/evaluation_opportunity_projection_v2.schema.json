{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evaluation_opportunity_projection_v2"
    },
    "snapshot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "agent_id": {
      "type": "string",
      "enum": [
        "china",
        "us_economy",
        "eu_economy",
        "central_bank",
        "us_financial_conditions",
        "euro_area_financial_conditions",
        "commodities",
        "geopolitical",
        "market_breadth",
        "institutional_flow",
        "semiconductor",
        "technology",
        "energy",
        "biotech",
        "consumer",
        "industrials",
        "real_estate_construction",
        "financials",
        "agriculture",
        "relationship_mapper",
        "druckenmiller",
        "munger",
        "burry",
        "ackman",
        "cro",
        "alpha_discovery",
        "autonomous_execution",
        "cio"
      ]
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "pit_status": {
      "type": "string",
      "const": "VERIFIED"
    },
    "projection_status": {
      "type": "string",
      "enum": [
        "AVAILABLE",
        "GENERATION_FAILURE"
      ]
    },
    "qualification_predicate_version": {
      "type": "string",
      "minLength": 1
    },
    "member_refs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "source_evidence_by_required_source_id": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "uniqueItems": true
      }
    },
    "error_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "CONTRACT_MISMATCH",
          "EMPTY_REQUIRED_OPPORTUNITY_SET",
          "PIT_UNVERIFIED",
          "REQUIRED_DATA_UNAVAILABLE",
          "SOURCE_COVERAGE_UNHEALTHY"
        ]
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schema_version",
    "snapshot_hash",
    "agent_id",
    "as_of",
    "generated_at",
    "pit_status",
    "projection_status",
    "qualification_predicate_version",
    "member_refs",
    "source_evidence_by_required_source_id",
    "error_codes"
  ],
  "additionalProperties": false
}
