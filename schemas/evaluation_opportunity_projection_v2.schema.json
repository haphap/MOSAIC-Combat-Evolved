{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evaluation_opportunity_projection_v2"
    },
    "snapshot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "agent_id": {
      "type": "string",
      "enum": [
        "china",
        "us_economy",
        "eu_economy",
        "central_bank",
        "us_financial_conditions",
        "euro_area_financial_conditions",
        "commodities",
        "geopolitical",
        "market_breadth",
        "institutional_flow",
        "semiconductor",
        "technology",
        "energy",
        "biotech",
        "consumer",
        "industrials",
        "real_estate_construction",
        "financials",
        "agriculture",
        "relationship_mapper",
        "druckenmiller",
        "munger",
        "burry",
        "ackman",
        "cro",
        "alpha_discovery",
        "autonomous_execution",
        "cio"
      ]
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "pit_status": {
      "type": "string",
      "const": "VERIFIED"
    },
    "projection_status": {
      "type": "string",
      "enum": [
        "AVAILABLE",
        "GENERATION_FAILURE"
      ]
    },
    "qualification_predicate_version": {
      "type": "string",
      "enum": [
        "ackman_frozen_layer2_candidate_set_v2",
        "agriculture_sector_opportunity_set_v3",
        "alpha_novel_candidate_opportunity_set_v2",
        "execution_frozen_order_intent_opportunity_set_v2",
        "biotech_sector_opportunity_set_v3",
        "burry_frozen_layer2_candidate_set_v2",
        "central_bank_macro_opportunity_set_v2",
        "china_macro_opportunity_set_v2",
        "cio_pre_cio_portfolio_opportunity_set_v2",
        "commodities_macro_opportunity_set_v2",
        "consumer_sector_opportunity_set_v3",
        "cro_pre_cro_candidate_opportunity_set_v2",
        "druckenmiller_frozen_layer2_candidate_set_v2",
        "energy_sector_opportunity_set_v3",
        "eu_economy_macro_opportunity_set_v2",
        "euro_area_financial_conditions_macro_opportunity_set_v2",
        "financials_sector_opportunity_set_v3",
        "geopolitical_macro_opportunity_set_v2",
        "industrials_sector_opportunity_set_v3",
        "institutional_flow_macro_opportunity_set_v2",
        "market_breadth_macro_opportunity_set_v2",
        "munger_frozen_layer2_candidate_set_v2",
        "real_estate_construction_sector_opportunity_set_v3",
        "relationship_edge_candidate_opportunity_set_v2",
        "semiconductor_sector_opportunity_set_v3",
        "technology_sector_opportunity_set_v3",
        "us_economy_macro_opportunity_set_v2",
        "us_financial_conditions_macro_opportunity_set_v2"
      ]
    },
    "member_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": { "event_id": { "type": "string", "minLength": 1 } },
            "required": ["event_id"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": { "path_snapshot_id": { "type": "string", "minLength": 1 } },
            "required": ["path_snapshot_id"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "subindustry_id": { "type": "string", "minLength": 1 },
              "security_shortlist_id": { "type": "string", "minLength": 1 },
              "security_shortlist_hash": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "security_ts_codes": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            },
            "required": [
              "subindustry_id",
              "security_shortlist_id",
              "security_shortlist_hash",
              "security_ts_codes"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "candidate_ref": { "type": "string", "minLength": 1 },
              "ts_code": { "type": "string", "minLength": 1 }
            },
            "required": ["candidate_ref", "ts_code"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "edge_candidate_id": { "type": "string", "minLength": 1 },
              "materiality_weight": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "required": ["edge_candidate_id", "materiality_weight"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "risk_candidate_id": { "type": "string", "minLength": 1 },
              "ts_code": { "type": "string", "pattern": "^[0-9]{6}\\.(SH|SZ|BJ)$" },
              "proposed_target_weight": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "required": ["risk_candidate_id", "ts_code", "proposed_target_weight"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "order_intent_id": { "type": "string", "minLength": 1 },
              "ts_code": { "type": "string", "pattern": "^[0-9]{6}\\.(SH|SZ|BJ)$" },
              "action": { "type": "string", "enum": ["BUY", "SELL", "REDUCE"] },
              "requested_delta_weight": {
                "type": "number",
                "minimum": -1,
                "maximum": 1,
                "not": { "const": 0 }
              }
            },
            "required": ["order_intent_id", "ts_code", "action", "requested_delta_weight"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "controlled_target_set_id": { "type": "string", "minLength": 1 },
              "baseline_cash_weight": { "type": "number", "minimum": 0, "maximum": 1 },
              "positions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "position_ref": { "type": "string", "minLength": 1 },
                    "ts_code": { "type": "string", "pattern": "^[0-9]{6}\\.(SH|SZ|BJ)$" },
                    "baseline_weight": { "type": "number", "minimum": 0, "maximum": 1 },
                    "controlled_target_weight": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  },
                  "required": [
                    "position_ref",
                    "ts_code",
                    "baseline_weight",
                    "controlled_target_weight"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": ["controlled_target_set_id", "baseline_cash_weight", "positions"],
            "additionalProperties": false
          }
        ]
      }
    },
    "source_evidence_by_required_source_id": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "uniqueItems": true
      }
    },
    "error_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "CONTRACT_MISMATCH",
          "EMPTY_REQUIRED_OPPORTUNITY_SET",
          "PIT_UNVERIFIED",
          "REQUIRED_DATA_UNAVAILABLE",
          "SOURCE_COVERAGE_UNHEALTHY"
        ]
      },
      "uniqueItems": true
    }
  },
  "required": [
    "schema_version",
    "snapshot_hash",
    "agent_id",
    "as_of",
    "generated_at",
    "pit_status",
    "projection_status",
    "qualification_predicate_version",
    "member_refs",
    "source_evidence_by_required_source_id",
    "error_codes"
  ],
  "additionalProperties": false
}
