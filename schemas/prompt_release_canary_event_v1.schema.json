{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Release Canary Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "release_id",
    "account_mode",
    "traffic_percent",
    "agent",
    "stage",
    "stage_snapshot_hash",
    "observed_at",
    "schema_failed",
    "fallback",
    "source_failed",
    "unsupported_influence_rejected",
    "validator_rejected",
    "latency_ms",
    "token_budget_breached",
    "duplicate_order_intent_count",
    "exposure_breach_count"
  ],
  "properties": {
    "schema_version": { "const": "prompt_release_canary_event_v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "release_id": { "type": "string", "minLength": 1 },
    "account_mode": { "enum": ["paper", "backtest", "live"] },
    "traffic_percent": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 100 },
    "agent": { "type": "string", "minLength": 1 },
    "stage": {
      "enum": [
        "agent_run",
        "alpha_discovery",
        "cio_proposal",
        "cro_review",
        "execution_feasibility",
        "cio_final"
      ]
    },
    "stage_snapshot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "observed_at": { "type": "string", "format": "date-time" },
    "schema_failed": { "type": "boolean" },
    "fallback": { "type": "boolean" },
    "source_failed": { "type": "boolean" },
    "unsupported_influence_rejected": { "type": "boolean" },
    "validator_rejected": { "type": "boolean" },
    "latency_ms": { "type": "number", "minimum": 0 },
    "token_budget_breached": { "type": "boolean" },
    "duplicate_order_intent_count": { "type": "integer", "minimum": 0 },
    "exposure_breach_count": { "type": "integer", "minimum": 0 }
  }
}
