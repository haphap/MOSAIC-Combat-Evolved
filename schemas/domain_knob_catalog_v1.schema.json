{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Knob Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "catalog_version",
    "runtime_agent_count",
    "runtime_sources",
    "evaluation_metrics",
    "agents"
  ],
  "properties": {
    "schema_version": {
      "const": "domain_knob_catalog_v1"
    },
    "catalog_version": {
      "const": "domain_knob_catalog_v1"
    },
    "runtime_agent_count": {
      "type": "integer",
      "minimum": 1
    },
    "runtime_sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scope_schema",
          "schema_ref",
          "max_age",
          "trading_calendar",
          "pit_required",
          "empty_allowed",
          "empty_status",
          "empty_behavior",
          "stale_policy",
          "source_error_policy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "scope_schema": {
            "type": "object",
            "additionalProperties": {
              "enum": ["required", "optional"]
            }
          },
          "schema_ref": {
            "type": "string",
            "minLength": 1
          },
          "max_age": {
            "type": "string",
            "minLength": 1
          },
          "trading_calendar": {
            "enum": ["cn_a_share", "run_clock"]
          },
          "pit_required": {
            "type": "boolean"
          },
          "empty_allowed": {
            "type": "boolean"
          },
          "empty_status": {
            "enum": ["empty_confirmed", "invalid"]
          },
          "empty_behavior": {
            "enum": ["allow_empty", "disable_dependent_cards", "invalid"]
          },
          "stale_policy": {
            "enum": ["disable_card_and_cap_if_required", "disable_card", "invalid"]
          },
          "source_error_policy": {
            "enum": ["disable_card_and_cap_if_required", "disable_card", "invalid"]
          }
        }
      }
    },
    "evaluation_metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "unit",
          "value_convention",
          "direction",
          "aggregation",
          "window",
          "baseline",
          "min_sample_size",
          "pit_required",
          "exclusion_rules"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "unit": {
            "enum": ["ratio", "bps", "count", "score", "currency", "registered_custom_unit"]
          },
          "value_convention": {
            "enum": [
              "signed_return",
              "nonnegative_loss_magnitude",
              "rate_0_1",
              "bps_cost",
              "score",
              "count"
            ]
          },
          "direction": {
            "enum": ["higher_is_better", "lower_is_better"]
          },
          "aggregation": {
            "enum": [
              "mean",
              "median",
              "p50",
              "p95",
              "max",
              "min",
              "sum",
              "hit_rate",
              "calibration_error",
              "rank_correlation"
            ]
          },
          "window": {
            "type": "string",
            "minLength": 1
          },
          "baseline": {
            "enum": [
              "previous_knob_snapshot",
              "cohort_control",
              "shadow_ab",
              "rolling_window"
            ]
          },
          "min_sample_size": {
            "type": "integer",
            "minimum": 1
          },
          "pit_required": {
            "type": "boolean"
          },
          "exclusion_rules": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "layer",
          "agent",
          "prompt_ir_agent",
          "min_mutable_domain_knobs",
          "card_count",
          "cards"
        ],
        "properties": {
          "layer": {
            "enum": ["macro", "sector", "superinvestor", "decision"]
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "prompt_ir_agent": {
            "type": "string",
            "minLength": 1
          },
          "min_mutable_domain_knobs": {
            "type": "integer",
            "minimum": 1
          },
          "card_count": {
            "type": "integer",
            "minimum": 1
          },
          "cards": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "owner_agent",
                "consumer_agents",
                "projection_bucket",
                "path",
                "type",
                "default",
                "coverage_level",
                "runtime_input_sources",
                "runtime_input_source_policies",
                "evidence_dependencies",
                "evidence_dependency_policies",
                "learning_objective",
                "prediction_target",
                "evaluation_metric",
                "horizon",
                "rollback_condition",
                "enforcement",
                "category",
                "cross_field_group",
                "weight_group",
                "normalization"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "owner_agent": {
                  "type": "string",
                  "minLength": 1
                },
                "consumer_agents": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "projection_bucket": {
                  "enum": ["lookbacks", "thresholds"]
                },
                "path": {
                  "type": "string",
                  "pattern": "^/rule_packs/"
                },
                "type": {
                  "enum": ["number", "integer", "enum", "boolean"]
                },
                "default": {
                  "type": ["number", "string", "boolean"]
                },
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                },
                "step": {
                  "type": "number"
                },
                "allowed_values": {
                  "type": "array"
                },
                "coverage_level": {
                  "enum": ["direct_tool", "derived_proxy", "runtime_state", "gap_pending_tool"]
                },
                "runtime_input_sources": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "runtime_input_source_policies": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": {
                      "enum": [
                        "disable_card",
                        "disable_card_and_cap_if_required",
                        "allow",
                        "exclude_sample_only",
                        "invalid"
                      ]
                    }
                  }
                },
                "evidence_dependencies": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "dependency_id",
                      "evidence_key",
                      "tool",
                      "metric_ids",
                      "freshness",
                      "required_for_prediction",
                      "dependency_type",
                      "scope_resolution",
                      "scope_schema",
                      "min_scope_coverage"
                    ],
                    "properties": {
                      "dependency_id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "evidence_key": {
                        "type": "string",
                        "minLength": 1
                      },
                      "tool": {
                        "type": "string",
                        "minLength": 1
                      },
                      "metric_ids": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "freshness": {
                        "type": "string",
                        "minLength": 1
                      },
                      "required_for_prediction": {
                        "type": "boolean"
                      },
                      "dependency_type": {
                        "enum": ["direct_tool", "derived_proxy"]
                      },
                      "scope_resolution": {
                        "enum": ["pre_run", "in_run_tool_derived"]
                      },
                      "scope_schema": {
                        "type": "object",
                        "additionalProperties": {
                          "enum": ["required", "optional"]
                        }
                      },
                      "min_scope_coverage": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                      },
                      "scope_source_tool": {
                        "type": "string"
                      },
                      "scope_source_evidence_key": {
                        "type": "string"
                      },
                      "max_scope_count": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "min_scope_count": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "empty_scope_behavior": {
                        "enum": ["allow_empty", "exclude_sample", "invalid"]
                      }
                    },
                    "allOf": [
                      {
                        "if": {
                          "properties": {
                            "scope_resolution": {
                              "const": "in_run_tool_derived"
                            }
                          },
                          "required": ["scope_resolution"]
                        },
                        "then": {
                          "required": [
                            "scope_source_tool",
                            "scope_source_evidence_key",
                            "max_scope_count",
                            "min_scope_count",
                            "empty_scope_behavior"
                          ]
                        }
                      }
                    ]
                  }
                },
                "evidence_dependency_policies": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": {
                      "enum": [
                        "allow",
                        "exclude_sample_only",
                        "exclude_sample_and_cap_if_required",
                        "mark_unsupported_influence",
                        "reject_output",
                        "invalid"
                      ]
                    }
                  }
                },
                "learning_objective": {
                  "type": "string",
                  "minLength": 1
                },
                "prediction_target": {
                  "type": "string",
                  "minLength": 1
                },
                "evaluation_metric": {
                  "type": "string",
                  "minLength": 1
                },
                "horizon": {
                  "type": "string",
                  "minLength": 1
                },
                "rollback_condition": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["metric", "worse_by", "unit"],
                  "properties": {
                    "metric": {
                      "type": "string",
                      "minLength": 1
                    },
                    "worse_by": {
                      "type": "number",
                      "minimum": 0
                    },
                    "unit": {
                      "enum": ["ratio", "bps", "count", "score", "currency", "registered_custom_unit"]
                    }
                  }
                },
                "enforcement": {
                  "enum": ["advisory", "code"]
                },
                "runtime_validator": {
                  "type": "string"
                },
                "audit_field": {
                  "type": "string"
                },
                "category": {
                  "const": "domain"
                },
                "cross_field_group": {
                  "type": ["string", "null"]
                },
                "weight_group": {
                  "type": ["string", "null"]
                },
                "normalization": {
                  "enum": ["none", "sum_to_one"]
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "type": {
                        "enum": ["number", "integer"]
                      }
                    },
                    "required": ["type"]
                  },
                  "then": {
                    "required": ["min", "max", "step"]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "enum"
                      }
                    },
                    "required": ["type"]
                  },
                  "then": {
                    "required": ["allowed_values"]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "coverage_level": {
                        "enum": ["direct_tool", "derived_proxy"]
                      }
                    },
                    "required": ["coverage_level"]
                  },
                  "then": {
                    "properties": {
                      "evidence_dependencies": {
                        "minItems": 1
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "coverage_level": {
                        "const": "runtime_state"
                      }
                    },
                    "required": ["coverage_level"]
                  },
                  "then": {
                    "properties": {
                      "runtime_input_sources": {
                        "minItems": 1
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "enforcement": {
                        "const": "code"
                      }
                    },
                    "required": ["enforcement"]
                  },
                  "then": {
                    "required": ["runtime_validator", "audit_field"]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
