{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Claim Graph v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "snapshot_hash",
    "evidence_ledger",
    "claims",
    "recommendation_claim_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "evidence_claim_graph_v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_hash": {
      "$ref": "#/$defs/sha256"
    },
    "evidence_ledger": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "recommendation_claim_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/output_claim_reference"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "run_id",
        "snapshot_hash",
        "source_kind",
        "tool_or_source",
        "metric",
        "value",
        "unit",
        "as_of",
        "lookback",
        "freshness",
        "fallback",
        "source_fingerprint",
        "direction",
        "privacy_class"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_hash": {
          "$ref": "#/$defs/sha256"
        },
        "source_kind": {
          "enum": ["tool", "runtime_source", "derived_metric"]
        },
        "tool_or_source": {
          "type": "string",
          "minLength": 1
        },
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "value": {},
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "as_of": {
          "type": "string",
          "minLength": 1
        },
        "lookback": {
          "type": "string",
          "minLength": 1
        },
        "freshness": {
          "enum": ["current", "stale", "missing", "fallback", "tool_failed"]
        },
        "fallback": {
          "type": "boolean"
        },
        "source_fingerprint": {
          "$ref": "#/$defs/sha256"
        },
        "direction": {
          "enum": ["positive", "negative", "neutral", "ambiguous"]
        },
        "privacy_class": {
          "enum": ["public_structured", "private_runtime", "licensed_private"]
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_type",
        "statement",
        "structured_conclusion",
        "evidence_refs",
        "research_rule_refs",
        "snapshot_hash"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "enum": ["fact", "inference", "uncertainty"]
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "structured_conclusion": {
          "type": "object"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "research_rule_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "snapshot_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "output_claim_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_id", "output_type", "claim_refs"],
      "properties": {
        "output_id": {
          "type": "string",
          "minLength": 1
        },
        "output_type": {
          "enum": ["recommendation", "candidate", "position_decision", "portfolio_action"]
        },
        "claim_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
