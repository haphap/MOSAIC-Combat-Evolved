{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RKE Report Intelligence Confidence Impact Monitor",
  "type": "object",
  "required": [
    "monitor_id",
    "run_id",
    "as_of_datetime",
    "recipe_count",
    "observation_count",
    "paper_trading_validated_recipe_count",
    "blocked_recipe_count",
    "unvalidated_confidence_impact_count",
    "alpha_decay_watch_count",
    "alpha_decay_fail_count",
    "cost_decay_fail_count",
    "calibration_drift_count",
    "regime_fragile_alpha_count",
    "drift_status_counts",
    "recommended_action_counts",
    "blocker_counts",
    "tracked_recipe_ids",
    "alpha_decay_recipe_ids",
    "cost_decay_recipe_ids",
    "calibration_drift_recipe_ids",
    "regime_fragile_recipe_ids",
    "manual_review_recipe_ids",
    "freeze_recipe_ids",
    "retire_recipe_ids",
    "production_decision_impact_allowed",
    "lockbox_required_before_production_impact",
    "policy"
  ],
  "properties": {
    "monitor_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "as_of_datetime": {"type": "string", "minLength": 1},
    "recipe_count": {"type": "integer", "minimum": 0},
    "observation_count": {"type": "integer", "minimum": 0},
    "paper_trading_validated_recipe_count": {"type": "integer", "minimum": 0},
    "blocked_recipe_count": {"type": "integer", "minimum": 0},
    "unvalidated_confidence_impact_count": {"type": "integer", "minimum": 0},
    "alpha_decay_watch_count": {"type": "integer", "minimum": 0},
    "alpha_decay_fail_count": {"type": "integer", "minimum": 0},
    "cost_decay_fail_count": {"type": "integer", "minimum": 0},
    "calibration_drift_count": {"type": "integer", "minimum": 0},
    "regime_fragile_alpha_count": {"type": "integer", "minimum": 0},
    "drift_status_counts": {"type": "object"},
    "recommended_action_counts": {"type": "object"},
    "blocker_counts": {"type": "object"},
    "tracked_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "alpha_decay_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "cost_decay_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "calibration_drift_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "regime_fragile_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "manual_review_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "freeze_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "retire_recipe_ids": {"type": "array", "items": {"type": "string"}},
    "production_decision_impact_allowed": {"type": "boolean", "const": false},
    "lockbox_required_before_production_impact": {"type": "boolean"},
    "policy": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
