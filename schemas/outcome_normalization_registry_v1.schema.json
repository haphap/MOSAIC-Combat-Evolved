{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "registry_version": {
      "type": "string",
      "const": "outcome_normalization_registry_v1"
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "normalization_contract_version": {
            "type": "string",
            "minLength": 1
          },
          "effective_at": {
            "type": "string",
            "format": "date-time"
          },
          "scale": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "scale_authority": {
            "type": "string",
            "enum": [
              "PRE_REGISTERED_COLD_START_UNIT_SCALE",
              "PIT_CALIBRATED_RELEASE"
            ]
          },
          "calibration_sample_count": {
            "type": "integer",
            "minimum": 0
          },
          "calibration_window_end": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        },
        "required": [
          "normalization_contract_version",
          "effective_at",
          "scale",
          "scale_authority",
          "calibration_sample_count",
          "calibration_window_end"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["registry_version", "registry_hash", "entries"],
  "additionalProperties": false
}
