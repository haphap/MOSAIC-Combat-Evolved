  "properties": {
    "metric_candidate_id": {"type": "string", "minLength": 1},
    "canonical_name": {"type": "string", "minLength": 1},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "metric_family": {"type": "string", "minLength": 1},
    "market": {"type": "string", "minLength": 1},
    "raw_data_requirements": {"type": "array"},
    "default_transformation": {"type": "object"},
    "mentioned_by": {"type": "object"},
    "target_agents": {"type": "array", "items": {"type": "string"}},
    "current_tool_coverage": {"type": "string", "minLength": 1},
    "existing_tool_ids": {"type": "array", "items": {"type": "string"}},
    "priority_bucket": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
