{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Release Canary Assignment Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "run_id",
    "agent_invocation_id",
    "release_id",
    "account_mode",
    "traffic_percent",
    "agent",
    "stage",
    "stage_snapshot_hash",
    "observed_at"
  ],
  "properties": {
    "schema_version": { "const": "prompt_release_canary_assignment_event_v1" },
    "event_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_invocation_id": { "type": "string", "minLength": 1 },
    "release_id": { "type": "string", "minLength": 1 },
    "account_mode": { "enum": ["paper", "backtest", "live"] },
    "traffic_percent": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 100 },
    "agent": { "type": "string", "minLength": 1 },
    "stage": {
      "enum": [
        "agent_run",
        "alpha_discovery",
        "cio_proposal",
        "cro_review",
        "execution_feasibility",
        "cio_final"
      ]
    },
    "stage_snapshot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "observed_at": { "type": "string", "format": "date-time" }
  }
}
